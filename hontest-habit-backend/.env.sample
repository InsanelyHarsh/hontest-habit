# App
# APP_MODE: server (default, runs the webserver) | migrator (applies DB migrations then exits)
APP_MODE=server
APP_PORT=8080

# Postgres
# Values match docker-compose.yml's postgres service (POSTGRES_USER/
# POSTGRES_PASSWORD/POSTGRES_DB), which publishes 5432 to the host — so
# `docker compose up` + `go run ./cmd`/`make run` on the host both work
# against the same database.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=hontest_habit
DB_SSLMODE=disable

# Redis
# Matches docker-compose.yml's redis service, which publishes 6379 to the
# host.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=changeme-in-production
